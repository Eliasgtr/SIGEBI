<Window x:Class="Sigebi.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SIGEBI · Escritorio (personal bibliotecario)" Height="760" Width="1120">
    <DockPanel>
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Listo" />
            </StatusBarItem>
        </StatusBar>
        <TabControl Margin="8">
            <TabItem Header="Inventario">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBox x:Name="InventorySearch" Width="280" Margin="0,0,8,0" />
                        <Button Content="Buscar" Width="100" Click="OnSearchBooksClick" />
                    </StackPanel>
                    <DataGrid x:Name="BooksGrid" Grid.Row="1" AutoGenerateColumns="True" IsReadOnly="True" />
                    <GroupBox Grid.Row="2" Header="Alta de libro + primer ejemplar" Margin="0,8,0,0">
                        <Grid Margin="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBox x:Name="NewTitle" Grid.Row="0" Grid.Column="0" Margin="4" ToolTip="Título" />
                            <TextBox x:Name="NewAuthor" Grid.Row="0" Grid.Column="1" Margin="4" ToolTip="Autor" />
                            <TextBox x:Name="NewIsbn" Grid.Row="0" Grid.Column="2" Margin="4" ToolTip="ISBN" />
                            <TextBox x:Name="NewCategory" Grid.Row="1" Grid.Column="0" Margin="4" ToolTip="Categoría" />
                            <TextBox x:Name="NewInventory" Grid.Row="1" Grid.Column="1" Margin="4" ToolTip="Código inventario" />
                            <Button Grid.Row="1" Grid.Column="2" Margin="4" Content="Registrar" Click="OnRegisterBookClick" />
                            <StackPanel Grid.Row="2" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="4">
                                <TextBlock VerticalAlignment="Center" Text="Eliminar libro Id:" />
                                <TextBox x:Name="DeleteBookId" Width="80" Margin="8,0,8,0" />
                                <Button Content="Eliminar" Click="OnDeleteBookClick" />
                            </StackPanel>
                        </Grid>
                    </GroupBox>
                </Grid>
            </TabItem>
            <TabItem Header="Solicitudes">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Button Grid.Row="0" Content="Actualizar" Width="120" HorizontalAlignment="Left" Click="OnRefreshPendingClick" />
                    <DataGrid x:Name="PendingGrid" Grid.Row="1" Margin="0,8,0,8" AutoGenerateColumns="True" IsReadOnly="True" />
                    <StackPanel Grid.Row="2" Orientation="Horizontal">
                        <TextBox x:Name="RejectReason" Width="360" Margin="0,0,8,0" Text="Motivo de rechazo" />
                        <Button Content="Aprobar seleccionada" Margin="0,0,8,0" Click="OnApproveClick" />
                        <Button Content="Rechazar seleccionada" Click="OnRejectClick" />
                    </StackPanel>
                </Grid>
            </TabItem>
            <TabItem Header="Préstamos / devoluciones">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Button Grid.Row="0" Content="Actualizar préstamos activos" Width="200" HorizontalAlignment="Left" Click="OnRefreshActiveClick" />
                    <DataGrid x:Name="ActiveLoansGrid" Grid.Row="1" Margin="0,8,0,8" AutoGenerateColumns="True" IsReadOnly="True" />
                    <GroupBox Grid.Row="2" Header="Préstamo directo (mostrador)">
                        <StackPanel Orientation="Horizontal" Margin="6">
                            <TextBlock Text="Usuario Id" VerticalAlignment="Center" />
                            <TextBox x:Name="DirectUserId" Width="70" Margin="8,0,8,0" />
                            <TextBlock Text="Ejemplar Id" VerticalAlignment="Center" />
                            <TextBox x:Name="DirectCopyId" Width="70" Margin="8,0,8,0" />
                            <Button Content="Registrar préstamo" Click="OnDirectLoanClick" />
                        </StackPanel>
                    </GroupBox>
                    <GroupBox Grid.Row="3" Header="Devolución" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal" Margin="6">
                            <TextBlock Text="Préstamo Id" VerticalAlignment="Center" />
                            <TextBox x:Name="ReturnLoanId" Width="90" Margin="8,0,8,0" />
                            <Button Content="Registrar devolución" Click="OnReturnClick" />
                        </StackPanel>
                    </GroupBox>
                </Grid>
            </TabItem>
            <TabItem Header="Reportes y sanciones">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" FontWeight="Bold" Text="Préstamos vencidos" />
                    <DataGrid x:Name="OverdueGrid" Grid.Row="1" Margin="0,4,0,8" AutoGenerateColumns="True" IsReadOnly="True" />
                    <TextBlock Grid.Row="2" FontWeight="Bold" Text="Penalizaciones pendientes" />
                    <DataGrid x:Name="PenaltiesGrid" Grid.Row="3" Margin="0,4,0,8" AutoGenerateColumns="True" IsReadOnly="True" />
                    <StackPanel Grid.Row="4" Orientation="Horizontal">
                        <TextBlock Text="Penalización Id" VerticalAlignment="Center" />
                        <TextBox x:Name="PenaltyIdBox" Width="90" Margin="8,0,8,0" />
                        <Button Content="Marcar como resuelta" Click="OnResolvePenaltyClick" />
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
