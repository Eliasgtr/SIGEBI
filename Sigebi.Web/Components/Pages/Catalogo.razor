@page "/catalogo"
@rendermode InteractiveServer
@inject SigebiApiClient Api

<PageTitle>Catálogo SIGEBI</PageTitle>

<h1>Catálogo bibliográfico</h1>
<p class="text-muted">Consulta disponibilidad y solicita préstamos en línea (canal web para estudiantes y docentes).</p>

<div class="row g-2 mb-3">
    <div class="col-md-6">
        <label class="form-label">Usuario</label>
        <select class="form-select" @bind="selectedUserId">
            @foreach (var u in users)
            {
                <option value="@u.Id">@u.FullName (@u.UserType)</option>
            }
        </select>
    </div>
    <div class="col-md-6">
        <label class="form-label">Buscar</label>
        <div class="input-group">
            <input class="form-control" @bind="searchText" placeholder="Título, autor, ISBN o categoría" />
            <button class="btn btn-primary" @onclick="SearchAsync" disabled="@isBusy">Buscar</button>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(statusMessage))
{
    <div class="alert @(statusIsError ? "alert-danger" : "alert-info")">@statusMessage</div>
}

@if (isBusy)
{
    <p>Cargando…</p>
}
else if (books.Count == 0)
{
    <p>No hay resultados.</p>
}
else
{
    <style>
        .books-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 1rem;
        }
        .book-card { transition: transform .12s ease, box-shadow .12s ease; }
        .book-card:hover { transform: translateY(-4px); box-shadow: 0 6px 18px rgba(0,0,0,.08); }
        .copy-chip { display:flex; align-items:center; justify-content:space-between; gap:.5rem; }
        .muted-small { font-size:.85rem; color:#6c757d; }
    </style>

    <div class="books-grid">
        @foreach (var book in books)
        {
            var availableCopies = book.Copies.Where(c => string.Equals(c.Status, "Available", StringComparison.OrdinalIgnoreCase)).ToList();
            if (availableCopies.Count == 0)
            {
                continue; // no mostrar libros sin copias disponibles
            }

            <div class="card book-card">
                <div class="card-body d-flex flex-column">
                    <div class="mb-2">
                        <h5 class="card-title mb-0">@book.Title</h5>
                        <div class="muted-small">@book.Author · @book.Isbn · @book.Category</div>
                    </div>

                    <div class="mt-auto">
                        <div class="mb-2 muted-small">Copias disponibles: @availableCopies.Count</div>
                        <div class="list-group">
                            @foreach (var copy in availableCopies)
                            {
                                <div class="list-group-item copy-chip">
                                    <div>
                                        <div><strong>@copy.InventoryCode</strong></div>
                                        <div class="muted-small">@copy.Status</div>
                                    </div>
                                    <div>
                                        <button class="btn btn-sm btn-outline-success" disabled="@(selectedUserId == 0 || isBusy)"
                                                @onclick="() => RequestAsync(copy.CopyId)">Solicitar</button>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    private readonly List<UserSummaryModel> users = new();
    private readonly List<BookCatalogModel> books = new();
    private int selectedUserId;
    private string searchText = string.Empty;
    private string? statusMessage;
    private bool statusIsError;
    private bool isBusy;

    protected override async Task OnInitializedAsync()
    {
        await ReloadUsersAsync();
        await SearchAsync();
    }

    private async Task ReloadUsersAsync()
    {
        isBusy = true;
        try
        {
            users.Clear();
            users.AddRange(await Api.GetUsersAsync());
            selectedUserId = users.FirstOrDefault()?.Id ?? 0;
        }
        catch (Exception ex)
        {
            SetStatus(ex.Message, true);
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task SearchAsync()
    {
        isBusy = true;
        statusMessage = null;
        try
        {
            books.Clear();
            books.AddRange(await Api.SearchBooksAsync(searchText));
        }
        catch (Exception ex)
        {
            SetStatus(ex.Message, true);
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task RequestAsync(int copyId)
    {
        if (selectedUserId == 0)
            return;

        isBusy = true;
        statusMessage = null;
        try
        {
            var id = await Api.RequestLoanAsync(selectedUserId, copyId);
            // Remove the copy from the local list so it disappears immediately from the UI
            RemoveCopyFromList(copyId);
            SetStatus($"Solicitud registrada (Id {id}). El personal bibliotecario la procesará desde el escritorio.", false);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            SetStatus(ex.Message, true);
        }
        finally
        {
            isBusy = false;
        }
    }

    private void RemoveCopyFromList(int copyId)
    {
        for (int i = 0; i < books.Count; i++)
        {
            var book = books[i];
            var copy = book.Copies.FirstOrDefault(c => c.CopyId == copyId);
            if (copy is not null)
            {
                book.Copies.Remove(copy);
                // If the book has no available copies left, remove the book from the list (we show only available ones)
                var anyAvailable = book.Copies.Any(c => string.Equals(c.Status, "Available", StringComparison.OrdinalIgnoreCase));
                if (!anyAvailable)
                {
                    books.RemoveAt(i);
                }
                return;
            }
        }
    }

    private void SetStatus(string message, bool error)
    {
        statusMessage = message;
        statusIsError = error;
    }
}
